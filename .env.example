# Application Configuration
APP_NAME="Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plagexpert
DB_USERNAME=root
DB_PASSWORD=

# Session, Cache, and Queue Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_TIMEOUT_MINUTES=480

CACHE_STORE=database
QUEUE_CONNECTION=database

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Storage Configuration (Cloudflare R2 for production, local for development)
FILESYSTEM_DISK=local
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_TOKEN=

# Telegram Notifications (for production alerts and OTP)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_VENDOR_CHAT_ID=
ADMIN_TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Cloudflare Turnstile (Bot Protection for public endpoints)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Mail Configuration (use 'log' for development, configure SMTP for production)
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="no-reply@plagexpert.com"
MAIL_FROM_NAME="PlagExpert"

# Vite Configuration for Frontend Assets
VITE_APP_NAME="Portal"

# Bcrypt Configuration (for password hashing)
BCRYPT_ROUNDS=12

# Additional Security Settings (adjust for production)
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1
